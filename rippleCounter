module rippleCounter(
        input clk, rst,
        output [2:0] state 
    );
    
    wire Q;
    
    tff first (
        .enable(btnU),
        .Clock(btnC),
        .Q(state[0]),
        .NotQ(Q)
    );
    
    tff second (
        .enable(btnU),
        .Clock(Q),
        .Q(state[1]),
        .NotQ(Q)
    );
    
    tff third (
        .enable(btnU),
        .Clock(Q),
        .Q(state[2]),
        .NotQ(Q)
    );
    
endmodule
