module tff (
    input enable, Clock, rst,
    output reg Q,
    output NotQ
);

    initial begin
        Q <= 0;
    end

    always @(posedge Clock or posedge rst) begin
        if (rst)
        Q <= 0;
        else if (enable)
            Q <= ~Q;
        else
            Q <= Q;
    end
    
    assign NotQ = ~Q;

endmodule
